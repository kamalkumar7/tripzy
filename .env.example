# Backend
FLASK_ENV=development
FLASK_DEBUG=false
FLASK_PORT=5000

# Comma-separated list of exact frontend origins allowed by CORS.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API-key launch gate. In production, set TRIPZY_AUTH_REQUIRED=true and use a long random key.
TRIPZY_AUTH_REQUIRED=false
TRIPZY_API_KEYS=

# Request and quota controls
MAX_CONTENT_LENGTH_BYTES=16384
MAX_USER_INPUT_CHARS=1000
REQUEST_TIMEOUT_SECONDS=40
TRIPZY_PLAN_RATE_LIMIT=50 per minute
TRIPZY_PLAN_DAILY_QUOTA=200 per day

# Redis is recommended in production for shared cache and distributed rate limiting.
REDIS_URL=
RATELIMIT_STORAGE_URI=memory://
CACHE_TTL_SECONDS=86400

# Use a Postgres URL from Supabase, Neon, or another provider in production.
# If omitted, the backend uses local SQLite at backend/data/tripzy.db.
DATABASE_URL=
TRIP_QUEUE_BACKEND=thread
TRIP_JOB_WORKERS=2

# AI and search providers
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_PLACES_API_KEY=
PEXELS_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_TRIPZY_API_KEY=
NEXT_PUBLIC_TRIPZY_PLAN_TIMEOUT_MS=180000
NEXT_PUBLIC_TRIPZY_POLL_INTERVAL_MS=2000
